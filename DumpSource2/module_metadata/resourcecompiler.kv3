				"CSmartPropOperationAPI::TraceInDirection" = 
				{
					m_BaseClasses = [  ]
					m_FriendlyName = "Trace In Direction"
					m_Description = "Perform a trace in a direction from a specified origin and stop when a surface is hit."
					m_MetaData = 
					{
						supported_domains = 
						{
							SmartPropEval = true
						}
						scope_to_dependency_name = 
						{
							resourcecompiler.dll = "@lib:resourcecompiler.dll!CSmartPropOperationAPI"
						}
						pulse_inparams = 
						{
							vOrigin = 
							{
								friendly_name = "Origin"
								description = "Specifies the origin point for the start of the trace. To trace from the current position, set to < 0, 0, 0 > and set the coordinate space to Element Space"
								advanced_view = false
								metadata = null
								type = "PVAL_VEC3"
								default_value = 
								[
									"PVAL_VEC3",
									[ 0.0, 0.0, 0.0 ],
								]
								associated_inflow_name = "InDefault"
							}
							nOriginSpace = 
							{
								friendly_name = "Origin Space"
								description = "Coordinate space the origin is specified in. Using Element space allows specifying a value relative to the current position. However, world space should generally be used when for variable values."
								advanced_view = false
								metadata = null
								type = "PVAL_SCHEMA_ENUM:SmartPropSpace_t"
								default_value = 
								[
									"PVAL_SCHEMA_ENUM:SmartPropSpace_t",
									"ELEMENT",
								]
								associated_inflow_name = "InDefault"
							}
							flOriginOffset = 
							{
								friendly_name = "Origin Offset"
								description = "Offset to apply to the specified origin along the trace direction to compute the starting point of the trace."
								advanced_view = false
								metadata = null
								type = "PVAL_FLOAT"
								default_value = 
								[
									"PVAL_FLOAT",
									0.0,
								]
								associated_inflow_name = "InDefault"
							}
							flSurfaceUpInfluence = 
							{
								friendly_name = "Surface Up Influence"
								description = "How much should the surface normal up direction influence the final orientation. [ 0, 1 ] where 0 = don't modify the orientation, 1 = completely re-orient to match the surface."
								advanced_view = false
								metadata = null
								type = "PVAL_FLOAT"
								default_value = 
								[
									"PVAL_FLOAT",
									0.0,
								]
								associated_inflow_name = "InDefault"
							}
							nNoHitResult = 
							{
								friendly_name = "No Hit Result"
								description = "Specifies the behavior when the trace does not hit a surface."
								advanced_view = false
								metadata = null
								type = "PVAL_SCHEMA_ENUM:TraceNoHitResult_t"
								default_value = 
								[
									"PVAL_SCHEMA_ENUM:TraceNoHitResult_t",
									"NOTHING",
								]
								associated_inflow_name = "InDefault"
							}
							bIgnoreToolMaterials = 
							{
								friendly_name = "Ignore Tool Materials"
								description = "Do not trace against tool materials (attribute 'tools.toolsmaterial')."
								advanced_view = false
								metadata = null
								type = "PVAL_BOOL"
								default_value = 
								[
									"PVAL_BOOL",
									true,
								]
								associated_inflow_name = "InDefault"
							}
							bIgnoreSky = 
