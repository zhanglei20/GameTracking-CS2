								default_value = 
								[
									"PVAL_SCHEMA_ENUM:SmartPropSpace_t",
									"WORLD",
								]
								associated_inflow_name = "Place"
							}
							bDefaultPathInWorldSpace = 
							{
								friendly_name = "Default Path In World Space"
								description = "If enabled, the default path values will be treated as world space values, if disabled they are treated as object space values. Typically it makes sense for literal values to be treated as being in object space, but if the values are being supplied by locators they will typically be in world space."
