				{
					m_BaseClasses = [  ]
					m_FriendlyName = "Add Material Override"
					m_Description = "Specifies a material replacement to apply to all following models. Mapping goes from the material specified by the model( including material group selection ) to the replacement material. Previous material overrides are not considered when determining the base material."
